// This source code is subject to the terms of the Mozilla Public License 2.0
// © Trading Dashboard — Volumized Order Blocks Long-Only Strategy

//@version=6
strategy("VOB Long-Only [1:3 Backtest]",
     overlay           = true,
     default_qty_type  = strategy.percent_of_equity,
     default_qty_value = 10,
     commission_type   = strategy.commission.percent,
     commission_value  = 0.05,
     slippage          = 2,
     max_bars_back     = 500)

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────────────────────

var string G1 = "OB Detection"
var string G2 = "Strategy"
var string G3 = "Display"

swingLen = input.int  (10,   "Swing Length",        minval=3,   maxval=50,   group=G1,
     tooltip="Bars on each side to confirm a pivot high. Matches the JS indicator setting.")
atrLen   = input.int  (10,   "ATR Length",          minval=5,   maxval=50,   group=G1)
atrMult  = input.float(3.5,  "Max OB Size (×ATR)", minval=0.5, maxval=10.0, step=0.5, group=G1,
     tooltip="OBs larger than this ATR multiple are ignored as noise.")

rrRatio  = input.float(3.0,  "Risk : Reward",       minval=0.5, maxval=20.0, step=0.5, group=G2)
slBuf    = input.float(0.1,  "SL Buffer (×ATR)",    minval=0.0, maxval=3.0,  step=0.1, group=G2,
     tooltip="SL is placed this many ATR-multiples below the OB bottom, to avoid wick stops.")
showBoxes = input.bool(true, "Show OB Boxes",                                group=G3)
showTable = input.bool(true, "Show Level Table",                             group=G3)

// ─────────────────────────────────────────────────────────────────────────────
// CORE CALCULATIONS
// ─────────────────────────────────────────────────────────────────────────────

atr = ta.atr(atrLen)

// Pivot highs confirmed swingLen bars after the actual pivot bar
ph = ta.pivothigh(high, swingLen, swingLen)

// ─────────────────────────────────────────────────────────────────────────────
// STATE
// ─────────────────────────────────────────────────────────────────────────────

var float swHPrice = na
var int   swHBar   = na
var bool  swHUsed  = false

var float bullTop    = na
var float bullBot    = na
var bool  bullActive = false
var int   bullBar    = na

// ─────────────────────────────────────────────────────────────────────────────
// SWING HIGH TRACKING
// ─────────────────────────────────────────────────────────────────────────────

if not na(ph)
    swHPrice := ph
    swHBar   := bar_index - swingLen
    swHUsed  := false

// ─────────────────────────────────────────────────────────────────────────────
// BULLISH OB FORMATION
// Price crosses above a swing high → find the candle with the LOWEST LOW
// between the swing high bar and the crossing bar → that candle is the OB.
// ─────────────────────────────────────────────────────────────────────────────

if not na(swHPrice) and not swHUsed and close > swHPrice and close[1] <= swHPrice
    swHUsed   := true
    int   lb   = math.min(bar_index - swHBar, 499)
    if lb > 0
        float loLow  = 1e15
        float loHigh = 1e15
        for i = 1 to lb
            if low[i] < loLow
                loLow  := low[i]
                loHigh := high[i]
        float sz = loHigh - loLow
        if sz > 0 and sz <= atr * atrMult
            bullTop    := loHigh
            bullBot    := loLow
            bullActive := true
            bullBar    := bar_index

// ─────────────────────────────────────────────────────────────────────────────
// INVALIDATION — OB discarded when price closes below its bottom
// ─────────────────────────────────────────────────────────────────────────────

if bullActive and low < bullBot
    bullActive := false

// ─────────────────────────────────────────────────────────────────────────────
// LONG ENTRY
// Candle wicks into bull OB zone AND closes above OB bottom (bounce confirmed)
// SL = OB bottom − ATR buffer   |   TP = entry + RR × risk (default 1:3)
// ─────────────────────────────────────────────────────────────────────────────

bool noPos = strategy.position_size == 0

if bullActive and noPos and low <= bullTop and close >= bullBot
    float sl = bullBot - atr * slBuf
    float tp = close + (close - sl) * rrRatio
    strategy.entry("Bull OB", strategy.long, comment="▲ OB")
    strategy.exit ("Bull OB ✕", "Bull OB", stop=sl, limit=tp)

// ─────────────────────────────────────────────────────────────────────────────
// VISUALS
// ─────────────────────────────────────────────────────────────────────────────

// ── OB Box ────────────────────────────────────────────────────────────────────
var box bullBox = na

if showBoxes and bullActive
    bool isNew = na(bullBox) or box.get_left(bullBox) != bullBar
    if isNew
        bullBox := box.new(bullBar, bullTop, bar_index, bullBot,
                           border_color = color.new(color.teal, 0),
                           bgcolor      = color.new(color.teal, 82),
                           border_width = 1,
                           text         = "Bull OB",
                           text_color   = color.new(color.teal, 0),
                           text_size    = size.tiny,
                           text_halign  = text.align_left,
                           text_valign  = text.align_top)
    else
        box.set_right(bullBox, bar_index)

// ── Entry Triangle ────────────────────────────────────────────────────────────
plotshape(bullActive and low <= bullTop and close >= bullBot and noPos,
          title="Bull OB Entry",
          style    = shape.triangleup,
          location = location.belowbar,
          color    = color.teal,
          size     = size.small)

// ── OB Mid-line ───────────────────────────────────────────────────────────────
plot(bullActive ? math.avg(bullTop, bullBot) : na, "Bull OB Mid",
     color=color.new(color.teal, 40), linewidth=1, style=plot.style_linebr)

// ── Info Table ────────────────────────────────────────────────────────────────
if showTable and barstate.islast
    var table tbl = table.new(position.top_right, 2, 3,
                              bgcolor      = color.new(color.black, 65),
                              border_color = color.new(color.gray, 60),
                              border_width = 1,
                              frame_color  = color.new(color.gray, 40),
                              frame_width  = 1)
    table.cell(tbl, 0, 0, "Bull OB", text_color=color.gray,  text_size=size.small, bgcolor=color.new(color.gray, 85))
    table.cell(tbl, 1, 0, "Level",   text_color=color.gray,  text_size=size.small, bgcolor=color.new(color.gray, 85))
    table.cell(tbl, 0, 1, "Top",     text_color=color.teal,  text_size=size.small)
    table.cell(tbl, 1, 1, bullActive ? str.tostring(math.round_to_mintick(bullTop)) : "—",
               text_color=color.teal, text_size=size.small)
    table.cell(tbl, 0, 2, "Bottom",  text_color=color.teal,  text_size=size.small)
    table.cell(tbl, 1, 2, bullActive ? str.tostring(math.round_to_mintick(bullBot)) : "—",
               text_color=color.teal, text_size=size.small)
