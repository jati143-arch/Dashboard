// This source code is subject to the terms of the Mozilla Public License 2.0
// © Trading Dashboard — Volumized Order Blocks Backtest Strategy

//@version=6
strategy("Volumized Order Blocks [Backtest v6]",
     overlay           = true,
     default_qty_type  = strategy.percent_of_equity,
     default_qty_value = 10,
     commission_type   = strategy.commission.percent,
     commission_value  = 0.05,
     slippage          = 2,
     max_bars_back     = 500)

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────────────────────

var string G1 = "OB Detection"
var string G2 = "Strategy"
var string G3 = "Display"

swingLen = input.int  (10,   "Swing Length",          minval=3,   maxval=50,   group=G1,
     tooltip="Number of bars on each side used to confirm a pivot high/low. Matches the JS indicator setting.")
atrLen   = input.int  (10,   "ATR Length",            minval=5,   maxval=50,   group=G1)
atrMult  = input.float(3.5,  "Max OB Size (×ATR)",    minval=0.5, maxval=10.0, step=0.5, group=G1,
     tooltip="Order blocks larger than this multiple of ATR are ignored as noise. Same filter as the JS indicator.")

rrRatio  = input.float(2.0,  "Risk : Reward",         minval=0.5, maxval=20.0, step=0.5, group=G2)
slBuf    = input.float(0.1,  "SL Buffer (×ATR)",      minval=0.0, maxval=3.0,  step=0.1, group=G2,
     tooltip="Stop-loss is placed this many ATR-multiples beyond the OB edge, to avoid getting stopped by spread/wick noise.")
tradeDir = input.string("Both", "Trade Direction",    options=["Both","Long Only","Short Only"], group=G2)
showBoxes = input.bool(true,  "Show OB Boxes",                                 group=G3)
showTable = input.bool(true,  "Show Level Table",                              group=G3)

// ─────────────────────────────────────────────────────────────────────────────
// CORE CALCULATIONS
// ─────────────────────────────────────────────────────────────────────────────

atr = ta.atr(atrLen)

// Pivot highs / lows — confirmed swingLen bars after the actual pivot bar
// ta.pivothigh returns the pivot price on the bar that is swingLen bars AFTER the pivot
ph = ta.pivothigh(high, swingLen, swingLen)
pl = ta.pivotlow (low,  swingLen, swingLen)

// ─────────────────────────────────────────────────────────────────────────────
// STATE
// ─────────────────────────────────────────────────────────────────────────────

// Last confirmed swing high
var float swHPrice = na
var int   swHBar   = na
var bool  swHUsed  = false   // prevents re-triggering on the same swing level

// Last confirmed swing low
var float swLPrice = na
var int   swLBar   = na
var bool  swLUsed  = false

// Active bullish OB (green zone — potential support)
var float bullTop    = na
var float bullBot    = na
var bool  bullActive = false
var int   bullBar    = na    // bar index where OB was formed

// Active bearish OB (red zone — potential resistance)
var float bearTop    = na
var float bearBot    = na
var bool  bearActive = false
var int   bearBar    = na

// ─────────────────────────────────────────────────────────────────────────────
// SWING TRACKING
// ─────────────────────────────────────────────────────────────────────────────

if not na(ph)
    swHPrice := ph
    swHBar   := bar_index - swingLen   // actual pivot bar (confirmed swingLen bars ago)
    swHUsed  := false                  // reset so the next crossing can form a new OB

if not na(pl)
    swLPrice := pl
    swLBar   := bar_index - swingLen
    swLUsed  := false

// ─────────────────────────────────────────────────────────────────────────────
// BULLISH OB FORMATION
// Price crosses above a swing high → find the candle with the LOWEST LOW
// between the swing high bar and the crossing bar → that candle is the OB.
// ─────────────────────────────────────────────────────────────────────────────

if not na(swHPrice) and not swHUsed and close > swHPrice and close[1] <= swHPrice
    swHUsed    := true
    int   lb    = math.min(bar_index - swHBar, 499)
    if lb > 0
        float loLow  = 1e15
        float loHigh = 1e15
        for i = 1 to lb
            if low[i] < loLow
                loLow  := low[i]
                loHigh := high[i]
        float sz = loHigh - loLow
        if sz > 0 and sz <= atr * atrMult
            bullTop    := loHigh
            bullBot    := loLow
            bullActive := true
            bullBar    := bar_index

// ─────────────────────────────────────────────────────────────────────────────
// BEARISH OB FORMATION
// Price crosses below a swing low → find the candle with the HIGHEST HIGH
// between the swing low bar and the crossing bar → that candle is the OB.
// ─────────────────────────────────────────────────────────────────────────────

if not na(swLPrice) and not swLUsed and close < swLPrice and close[1] >= swLPrice
    swLUsed    := true
    int   lb    = math.min(bar_index - swLBar, 499)
    if lb > 0
        float hiHigh = -1e15
        float hiLow  = -1e15
        for i = 1 to lb
            if high[i] > hiHigh
                hiHigh := high[i]
                hiLow  := low[i]
        float sz = hiHigh - hiLow
        if sz > 0 and sz <= atr * atrMult
            bearTop    := hiHigh
            bearBot    := hiLow
            bearActive := true
            bearBar    := bar_index

// ─────────────────────────────────────────────────────────────────────────────
// INVALIDATION
// An OB is broken (and discarded) when price closes beyond its far edge.
// Mirrors the JS invalidation: bull broken when low < ob.bottom, bear when high > ob.top
// ─────────────────────────────────────────────────────────────────────────────

if bullActive and low < bullBot
    bullActive := false

if bearActive and high > bearTop
    bearActive := false

// ─────────────────────────────────────────────────────────────────────────────
// STRATEGY ENTRIES
// Enter when price retraces INTO the OB zone.
// Bull OB: candle low dips into the zone AND closes above OB bottom (bounce)
// Bear OB: candle high pokes into the zone AND closes below OB top  (rejection)
// ─────────────────────────────────────────────────────────────────────────────

bool noPos = strategy.position_size == 0

// ── Long ──────────────────────────────────────────────────────────────────────
if bullActive and noPos and (tradeDir == "Both" or tradeDir == "Long Only")
    // Wick into OB zone, body holds above OB bottom → bullish entry
    if low <= bullTop and close >= bullBot
        float sl = bullBot - atr * slBuf
        float tp = close + (close - sl) * rrRatio
        strategy.entry("Bull OB", strategy.long, comment="▲ Bull OB")
        strategy.exit ("Bull OB ✕", "Bull OB", stop=sl, limit=tp)

// ── Short ─────────────────────────────────────────────────────────────────────
if bearActive and noPos and (tradeDir == "Both" or tradeDir == "Short Only")
    // Wick into OB zone, body holds below OB top → bearish entry
    if high >= bearBot and close <= bearTop
        float sl = bearTop + atr * slBuf
        float tp = close - (sl - close) * rrRatio
        strategy.entry("Bear OB", strategy.short, comment="▼ Bear OB")
        strategy.exit ("Bear OB ✕", "Bear OB", stop=sl, limit=tp)

// ─────────────────────────────────────────────────────────────────────────────
// VISUALS
// ─────────────────────────────────────────────────────────────────────────────

// ── OB Boxes ──────────────────────────────────────────────────────────────────
var box bullBox = na
var box bearBox = na

if showBoxes
    // Bullish OB — teal
    if bullActive
        bool newBull = na(bullBox) or box.get_left(bullBox) != bullBar
        if newBull
            bullBox := box.new(bullBar, bullTop, bar_index, bullBot,
                               border_color = color.new(color.teal, 0),
                               bgcolor      = color.new(color.teal, 82),
                               border_width = 1,
                               text         = "Bull OB",
                               text_color   = color.new(color.teal, 0),
                               text_size    = size.tiny,
                               text_halign  = text.align_left,
                               text_valign  = text.align_top)
        else
            box.set_right(bullBox, bar_index)

    // Bearish OB — red
    if bearActive
        bool newBear = na(bearBox) or box.get_left(bearBox) != bearBar
        if newBear
            bearBox := box.new(bearBar, bearTop, bar_index, bearBot,
                               border_color = color.new(color.red, 0),
                               bgcolor      = color.new(color.red, 82),
                               border_width = 1,
                               text         = "Bear OB",
                               text_color   = color.new(color.red, 0),
                               text_size    = size.tiny,
                               text_halign  = text.align_left,
                               text_valign  = text.align_top)
        else
            box.set_right(bearBox, bar_index)

// ── Entry Markers ─────────────────────────────────────────────────────────────
longSignal  = bullActive and low <= bullTop and close >= bullBot and noPos and
              (tradeDir == "Both" or tradeDir == "Long Only")
shortSignal = bearActive and high >= bearBot and close <= bearTop and noPos and
              (tradeDir == "Both" or tradeDir == "Short Only")

plotshape(longSignal,  title="Bull OB Entry",
          style=shape.triangleup,   location=location.belowbar,
          color=color.teal, size=size.small)
plotshape(shortSignal, title="Bear OB Entry",
          style=shape.triangledown, location=location.abovebar,
          color=color.red,  size=size.small)

// ── Mid-line plots (visible even without boxes) ────────────────────────────────
plot(bullActive ? math.avg(bullTop, bullBot) : na, "Bull OB Mid",
     color=color.new(color.teal, 40), linewidth=1, style=plot.style_linebr)
plot(bearActive ? math.avg(bearTop, bearBot) : na, "Bear OB Mid",
     color=color.new(color.red,  40), linewidth=1, style=plot.style_linebr)

// ── Info Table ────────────────────────────────────────────────────────────────
if showTable and barstate.islast
    var table tbl = table.new(position.top_right, 2, 5,
                              bgcolor      = color.new(color.black, 65),
                              border_color = color.new(color.gray, 60),
                              border_width = 1,
                              frame_color  = color.new(color.gray, 40),
                              frame_width  = 1)
    // Header
    table.cell(tbl, 0, 0, "Zone",   text_color=color.gray,  text_size=size.small, bgcolor=color.new(color.gray,85))
    table.cell(tbl, 1, 0, "Level",  text_color=color.gray,  text_size=size.small, bgcolor=color.new(color.gray,85))
    // Bull OB
    table.cell(tbl, 0, 1, "Bull top",    text_color=color.teal, text_size=size.small)
    table.cell(tbl, 1, 1, bullActive ? str.tostring(math.round_to_mintick(bullTop)) : "—", text_color=color.teal, text_size=size.small)
    table.cell(tbl, 0, 2, "Bull bot",    text_color=color.teal, text_size=size.small)
    table.cell(tbl, 1, 2, bullActive ? str.tostring(math.round_to_mintick(bullBot)) : "—", text_color=color.teal, text_size=size.small)
    // Bear OB
    table.cell(tbl, 0, 3, "Bear top",    text_color=color.red,  text_size=size.small)
    table.cell(tbl, 1, 3, bearActive ? str.tostring(math.round_to_mintick(bearTop)) : "—", text_color=color.red, text_size=size.small)
    table.cell(tbl, 0, 4, "Bear bot",    text_color=color.red,  text_size=size.small)
    table.cell(tbl, 1, 4, bearActive ? str.tostring(math.round_to_mintick(bearBot)) : "—", text_color=color.red, text_size=size.small)
